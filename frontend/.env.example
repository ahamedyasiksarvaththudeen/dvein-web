# ─────────────────────────────────────────────────────────────────────────────
# DVein Frontend — Firebase Environment Variables
# Copy this file to ".env" and fill in your Firebase project credentials.
# NEVER commit the real .env file to git.
# See FIREBASE_SETUP_GUIDE.md in the project root for step-by-step instructions.
# ─────────────────────────────────────────────────────────────────────────────

# All values come from:
#   Firebase Console → Your project → Project settings → Your apps → SDK snippet

VITE_FIREBASE_API_KEY=AIzaSy_replace_with_your_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
